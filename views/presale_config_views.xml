<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Lead Status Views -->
    <record id="view_lead_status_list" model="ir.ui.view">
        <field name="name">lead.status.list</field>
        <field name="model">lead.status</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="is_won_stage"/>
                <field name="is_lead_pipeline"/>
                <field name="color" widget="color_picker"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_lead_status_form" model="ir.ui.view">
        <field name="name">lead.status.form</field>
        <field name="model">lead.status</field>
        <field name="arch" type="xml">
            <form string="Lead Status">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="is_won_stage"/>
                            <field name="is_lead_pipeline"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="color" widget="color_picker"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Incoming Query Method Views -->
    <record id="view_incoming_query_method_list" model="ir.ui.view">
        <field name="name">incoming.query.method.list</field>
        <field name="model">incoming.query.method</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="color" widget="color_picker"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_incoming_query_method_form" model="ir.ui.view">
        <field name="name">incoming.query.method.form</field>
        <field name="model">incoming.query.method</field>
        <field name="arch" type="xml">
            <form string="Incoming Query Method">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="color" widget="color_picker"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Current Condition Views -->
    <record id="view_current_condition_list" model="ir.ui.view">
        <field name="name">current.condition.list</field>
        <field name="model">current.condition</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="color" widget="color_picker"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_current_condition_form" model="ir.ui.view">
        <field name="name">current.condition.form</field>
        <field name="model">current.condition</field>
        <field name="arch" type="xml">
            <form string="Current Condition">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="color" widget="color_picker"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>



    <!-- Actions -->
    <record id="action_lead_status" model="ir.actions.act_window">
        <field name="name">Status</field>
        <field name="res_model">lead.status</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_incoming_query_method" model="ir.actions.act_window">
        <field name="name">Method</field>
        <field name="res_model">incoming.query.method</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_current_condition" model="ir.actions.act_window">
        <field name="name">Condition</field>
        <field name="res_model">current.condition</field>
        <field name="view_mode">list,form</field>
    </record>



    <!-- Menu Items -->
    <menuitem id="menu_presale_config_root"
              name="Pre Sale"
              parent="crm.crm_menu_config"
              sequence="50"
              groups="sales_team.group_sale_manager"/>

    <menuitem id="menu_lead_status" name="Status" parent="menu_presale_config_root" action="action_lead_status" sequence="10"/>
    <menuitem id="menu_incoming_query_method" name="Method" parent="menu_presale_config_root" action="action_incoming_query_method" sequence="20"/>
    <menuitem id="menu_current_condition" name="Condition" parent="menu_presale_config_root" action="action_current_condition" sequence="30"/>
</odoo>
