<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Exclude Pre-Sale records from default CRM Lead views -->
    <record id="crm.crm_lead_all_leads" model="ir.actions.act_window">
        <field name="domain">['&amp;', ('is_presale', '!=', True), '|', ('type','=','lead'), ('type','=',False)]</field>
    </record>

    <!-- Exclude Pre-Sale records from Activity views -->
    <record id="crm.crm_lead_action_my_activities" model="ir.actions.act_window">
        <field name="domain">[("active", "in", [True, False]), ("activity_ids.active", "in", [True, False]), ('is_presale', '!=', True)]</field>
    </record>

    <!-- Exclude Pre-Sale records from Opportunity/Meeting views -->
    <record id="crm.crm_lead_opportunities" model="ir.actions.act_window">
        <field name="domain">[('type','=','opportunity'), ('is_presale', '!=', True)]</field>
    </record>

    <!-- Exclude Pre-Sale records from Pipeline views -->
    <record id="crm.crm_lead_action_pipeline" model="ir.actions.act_window">
        <field name="domain">[('type','=','opportunity'), ('is_presale', '!=', True)]</field>
    </record>

    <!-- Exclude Pre-Sale records from Forecast views -->
    <record id="crm.crm_lead_action_forecast" model="ir.actions.act_window">
        <field name="domain">[('type','=','opportunity'), ('is_presale', '!=', True)]</field>
    </record>
</odoo>
