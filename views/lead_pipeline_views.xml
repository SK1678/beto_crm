<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Lead Pipeline Views -->
    <record id="view_lead_pipeline_kanban" model="ir.ui.view">
        <field name="name">beto.crm.lead.pipeline.kanban</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_kanban_view_leads"/>
        <field name="mode">primary</field>
        <field name="priority">1000</field>
        <field name="arch" type="xml">
            <xpath expr="//kanban" position="attributes">
                <attribute name="default_group_by">lead_status_id</attribute>
            </xpath>
            <xpath expr="//field[@name='priority']" position="replace">
                <field name="priority" widget="priority"/>
            </xpath>
            <xpath expr="//footer//div[1]" position="inside">
                <field name="lead_status_id" widget="badge" options="{'color_field': 'status_color'}"/>
            </xpath>
        </field>
    </record>

    <record id="view_lead_pipeline_list" model="ir.ui.view">
        <field name="name">beto.crm.lead.pipeline.list</field>
        <field name="model">crm.lead</field>
        <field name="priority">1000</field>
        <field name="arch" type="xml">
            <list string="Lead Pipeline" default_order="id desc">
                <field name="id" string="ID"/>
                <field name="entry_date" string="Date of Entry" widget="date"/>
                <field name="partner_id" string="Client's Name"/>
                <field name="job_link" string="Link" widget="url"/>
                <field name="profile_id" string="Profile Name" widget="badge"/>
                <field name="lead_status_id" string="Status" widget="badge" options="{'color_field': 'status_color'}"/>
                <field name="note" string="Note"/>
                <field name="meeting_link" string="Meeting link" widget="url" text="meet"/>
                <field name="quote_html" string="Quote link" widget="html"/>
                <field name="priority" string="Priority" widget="priority" readonly="1"/>
                <field name="current_condition_id" string="Current condition" widget="badge" options="{'color_field': 'condition_color'}"/>
                
                <field name="status_color" column_invisible="True"/>
                <field name="condition_color" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_custom_lead_pipeline_form" model="ir.ui.view">
        <field name="name">beto.crm.lead.pipeline.form</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="mode">primary</field>
        <field name="priority">1000</field>
        <field name="arch" type="xml">
            <xpath expr="//header" position="replace">
                <header>
                    <button string="New Quotation" name="action_sale_quotations_new" type="object" class="oe_highlight" data-hotkey="q"
                        title="Create new quotation"
                        invisible="type == 'lead' or active == False"/>
                    <button name="action_set_won_rainbowman" string="Won"
                        type="object" class="btn-secondary" data-hotkey="w" title="Mark as won"
                        invisible="won_status == 'won' or type == 'lead' or not active"/>
                    <button name="%(crm.crm_lead_lost_action)d" string="Lost" type="action" class="btn-secondary" data-hotkey="l" title="Mark as lost"
                        invisible="won_status != 'pending' or not active"/>
                </header>
            </xpath>
            <xpath expr="//sheet" position="replace">
                <sheet>
                    <group>
                        <group string="PIPELINE INFORMATION">
                            <field name="id" string="ID" readonly="1" invisible="not id"/>
                            <field name="entry_date" string="Date of Entry"/>
                            <field name="partner_id" string="Client's Name" required="1"/>
                            <field name="job_link" string="Job Link" widget="url" required="1"/>
                            <field name="platform_source_id" string="Platform Source" required="1"/>
                            <field name="profile_id" string="Profile" required="1"/>
                            <field name="lead_status_id" string="Status"/>
                        </group>
                        <group string="">
                            <field name="priority" string="Priority" widget="priority"/>
                            <field name="current_condition_id" string="Current Condition" required="1"/>
                            <field name="meeting_link" string="Meeting Link" widget="url"/>
                            <field name="quote_link" string="Quote Link"/>
                            <field name="quote_display_text" string="Quote Link Display Text"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Notes" name="notes">
                            <field name="note" placeholder="Add notes about this pipeline lead..."/>
                        </page>
                    </notebook>
                </sheet>
            </xpath>
        </field>
    </record>

</odoo>
